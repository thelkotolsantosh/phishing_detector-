# ─────────────────────────────────────────────
#  .gitignore — Phishing Detector
# ─────────────────────────────────────────────

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
venv/
env/
.env/
.venv/
ENV/

# Jupyter checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints

# Model binaries (large files — use Git LFS or regenerate)
models/*.pkl
models/*.joblib

# Output images (regenerated on each run)
outputs/*.png
outputs/*.jpg
outputs/*.csv

# Log files
logs/*.log

# IDE / OS artifacts
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Coverage reports
htmlcov/
.coverage
.pytest_cache/

# Environment variables
.env
*.env
